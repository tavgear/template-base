http://{$DOMAIN}:80 {
    # Strapi uploads — Caddy serves directly (no Node round-trip)
    handle_path /uploads/* {
        root * /srv/uploads
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    # Everything else — Next.js
    reverse_proxy front:3000

    # Redirect /admin to Strapi admin
    redir /admin http://{$DOMAIN}:{$BACK_HTTP_PORT}/admin 302
}
