# Main
PROJECT_NAME=project
GITHUB_USER_NAME=gituser

# Application domain (e.g. test.google.tst)
DOMAIN=localhost

# Development user UID and name
DEV_USER_ID=1000
DEV_USER_NAME=devuser

# Front network settings
HTTP_PORT=80
HTTPS_PORT=443

# Back network setting
BACK_HTTP_PORT=1337
BACK_HTTP_PORT_EXT=5173

# Strapi settings
STRAPI_APP_KEYS: localDevKey1,localDevKey2,localDevKey3,localDevKey4
STRAPI_API_TOKEN_SALT: localApiTokenSalt2024
STRAPI_ADMIN_JWT_SECRET: localAdminJwtSecret2024
STRAPI_JWT_SECRET: localJwtSecret2024
STRAPI_TRANSFER_TOKEN_SALT: localTransferTokenSalt2024
STRAPI_ENCRYPTION_KEY: localEncryptionKey2024
